# Copy to .env and fill in all values before running docker-compose

# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Spring datasource (used when running outside Docker)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/quoterdb
SPRING_DATASOURCE_USERNAME=quoter
SPRING_DATASOURCE_PASSWORD=change_me_in_production

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security — must be at least 32 characters, never commit the real value
JWT_SECRET=replace_with_a_64_char_random_string_generated_by_openssl_rand

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Server
PORT=8080
